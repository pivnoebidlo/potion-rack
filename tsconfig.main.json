{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/main.ts", "src/preload.ts", "src/server.ts", "src/database/**/*", "src/controllers/**/*", "src/routes/**/*", "src/types/**/*"],
  "exclude": ["node_modules", "dist", "src/renderer"]
}