{
  "name": "potion-rack",
  "version": "0.1.1",
  "description": "Paint Manager for Miniatures",
  "author": {
    "name": "Potion Rack Team",
    "email": "potionrack@example.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "start": "npm run build && electron .",
    "postinstall": "electron-builder install-app-deps",
    "dist:mac": "npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux --x64"
  },
  "build": {
    "appId": "com.potionrack.app",
    "productName": "Potion Rack",
    "directories": {
      "output": "release",
      "app": "dist"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "!dist/**/*.map",
      "!dist/**/*.ts"
    ],
    "asarUnpack": ["**/*.node"],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Graphics"
    }
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "marked": "^18.0.3"
  }
}