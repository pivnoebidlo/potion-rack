{
  "name": "potion-rack",
  "version": "0.1.0",
  "description": "Paint Manager for Miniatures",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "start": "npm run build && electron .",
    "postinstall": "npm rebuild better-sqlite3 --runtime=electron --target=35.0.0 --disturl=https://electronjs.org/headers",
    "dist:mac": "npm run build && electron-builder --mac --arm64",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:linux": "npm run build && electron-builder --linux --x64"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "marked": "^18.0.3"
  }
}