{
  "name": "potion-rack",
  "version": "0.1.4",
  "description": "Paint Manager for Miniatures",
  "author": {
    "name": "Potion Rack Team",
    "email": "potionrack@example.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && npm run build:main",
    "start": "npm run build && electron .",
    "dev": "vite build --watch & electron .",
    "postinstall": "echo \"Skipping auto rebuild in CI\"",
    "rebuild": "npx @electron/rebuild -f -w better-sqlite3",
    "dist:mac": "npm run build && npm run rebuild && electron-builder --mac --arm64",
    "dist:win": "npm run build && npm run rebuild && electron-builder --win --x64",
    "dist:linux": "npm run build && npm run rebuild && electron-builder --linux --x64"
  },
  "build": {
    "appId": "com.potionrack.app",
    "productName": "Potion Rack",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "!dist/**/*.map",
      "!dist/**/*.ts"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/prismjs": "^1.26.6",
    "electron": "^35.7.5",
    "electron-builder": "^24.13.3",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.3",
    "@codemirror/language": "^6.11.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.36.5",
    "@lezer/highlight": "^1.2.1",
    "@lezer/markdown": "^1.4.2",
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/editor-plugin-code-syntax-highlight": "^3.1.0",
    "better-sqlite3": "^12.10.0",
    "codemirror": "^6.0.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "marked": "^18.0.3",
    "prismjs": "^1.30.0"
  }
}
