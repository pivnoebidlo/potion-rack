{
  "name": "potion-rack",
  "version": "0.5.5",
  "type": "commonjs",
  "description": "Paint Manager for Miniatures",
  "author": {
    "name": "Potion Rack Team",
    "email": "dima@niktokro.me"
  },
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:renderer && npm run build:main",
    "start": "npm run build && electron .",
    "dev": "vite build --watch & electron .",
    "postinstall": "echo \"Skipping auto rebuild in CI\"",
    "rebuild": "npx @electron/rebuild -f -w better-sqlite3",
    "dist:mac": "npm run build && npm run rebuild && electron-builder --mac --arm64",
    "dist:win": "npm run build && npm run rebuild && electron-builder --win --x64",
    "dist:linux": "npm run build && npm run rebuild && electron-builder --linux --x64"
  },
  "build": {
    "appId": "com.potionrack.app",
    "productName": "Potion Rack",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "!dist/**/*.map",
      "!dist/**/*.ts"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "publish": {
      "provider": "github",
      "owner": "pivnoebidlo",
      "repo": "potion-rack"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Graphics"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^35.7.5",
    "electron-builder": "^24.13.3",
    "purgecss": "^8.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.14",
    "vite-plugin-svgr": "^5.2.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.1",
    "@lezer/markdown": "^1.4.2",
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/editor-plugin-code-syntax-highlight": "^3.1.0",
    "@uiw/react-codemirror": "^4.25.10",
    "better-sqlite3": "^12.10.0",
    "codemirror": "^6.0.2",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "marked": "^18.0.4",
    "prismjs": "^1.30.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
